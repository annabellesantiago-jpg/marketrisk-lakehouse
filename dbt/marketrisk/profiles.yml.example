# Copy to ~/.dbt/profiles.yml and fill in credentials
marketrisk:
  target: dev
  outputs:
    dev:
      type: databricks
      host: "{{ env_var('DATABRICKS_HOST') }}"
      http_path: "{{ env_var('DATABRICKS_HTTP_PATH') }}"
      token: "{{ env_var('DATABRICKS_TOKEN') }}"
      catalog: market_risk_dev
      schema: silver
      threads: 4